{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skills Schema",
  "description": "Validation schema for src/data/skills.json — AI agent skills directory entries",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "slug", "name", "nameZh",
      "description", "descriptionEn", "descriptionJa", "descriptionEs", "descriptionFr",
      "developer", "developerZh", "repo", "agents", "category", "tags",
      "installCommand", "logo", "stars", "featured"
    ],
    "additionalProperties": false,
    "properties": {
      "slug":                { "type": "string", "minLength": 1 },
      "name":                { "type": "string", "minLength": 1 },
      "nameZh":              { "type": "string", "minLength": 1 },
      "description":         { "type": "string", "minLength": 1 },
      "descriptionEn":       { "type": "string", "minLength": 1 },
      "descriptionJa":       { "type": "string", "minLength": 1 },
      "descriptionEs":       { "type": "string", "minLength": 1 },
      "descriptionFr":       { "type": "string", "minLength": 1 },
      "developer":           { "type": "string", "minLength": 1 },
      "developerZh":         { "type": "string", "minLength": 1 },
      "repo":                { "type": "string", "minLength": 1 },
      "agents":              { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "category":            { "type": "string", "minLength": 1 },
      "tags":                { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "installCommand":      { "type": "string", "minLength": 1 },
      "logo":                { "type": "string", "minLength": 1 },
      "stars":               { "type": "number", "minimum": 0 },
      "featured":            { "type": "boolean" }
    }
  }
}
